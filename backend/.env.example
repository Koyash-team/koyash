APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Authentication (ADR-004). Secret used to sign JWT access tokens. Generate a
# strong random value in production, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`.
# The application falls back to a dev-only default if this is unset.
JWT_SECRET=<random-secret>
# JWT_EXPIRE_DAYS=7

# Password reset by email (US-27). Mail is sent through Resend's HTTPS API
# (https://resend.com), not SMTP — Railway blocks outbound SMTP (ports
# 25/465/587) on its Free/Hobby plans, so a plain SMTP sender can't deliver
# once deployed there. Resend rides on port 443 like normal web traffic, so it
# isn't blocked. See https://railway.com/deploy/resend-email-railway. Never
# commit these values: keep them in this git-ignored .env locally and in the
# Railway service variables in production. The mail is sent in the
# background, so an unreachable API never makes the user wait.
#   RESEND_API_KEY -> from the Resend dashboard, starts with "re_".
#   MAIL_FROM      -> must be on a domain verified with Resend, e.g.
#                     "Koyash <noreply@your-domain>"; use the sandbox address
#                     "onboarding@resend.dev" only for local testing.
RESEND_API_KEY=<re_your_resend_api_key>
MAIL_FROM=<noreply@your-domain>
# Where the reset link points (the deployed web app).
FRONTEND_URL=http://localhost:5173
# RESET_TOKEN_TTL_MINUTES=30

# LLM justification layer (ADR-001). Off unless LLM_ENABLED=true AND a key AND a
# system prompt are provided. The system prompt is customer-owned and not
# committed: put it in LLM_SYSTEM_PROMPT or the git-ignored
# backend/llm_system_prompt.txt (see backend/llm_system_prompt.example.txt).
LLM_ENABLED=false
LLM_API=<llm-api-key>
LLM_BASE_URL=https://api.vsellm.ru/v1
LLM_MODEL=openai/gpt-4o-mini
# LLM_SYSTEM_PROMPT=
