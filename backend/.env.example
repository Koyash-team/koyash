APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Authentication (ADR-004). Secret used to sign JWT access tokens. Generate a
# strong random value in production, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`.
# The application falls back to a dev-only default if this is unset.
JWT_SECRET=<random-secret>
# JWT_EXPIRE_DAYS=7

# Password reset by email (US-27). Mail is sent through the customer's own mail
# domain over SMTP — only sending is used, so the mailbox's POP3/IMAP settings
# are not needed here. Never commit these values: put them in this git-ignored
# .env locally and in the Railway service variables in production.
#   SMTP_PORT  -> the mail provider's SMTP *SSL/TLS* port (usually 465) with
#                 SMTP_SSL=true, or the plain SMTP port (usually 587) with
#                 SMTP_SSL=false, which upgrades the connection via STARTTLS.
SMTP_HOST=<outgoing-mail-server>
SMTP_PORT=465
SMTP_SSL=true
SMTP_USER=<mailbox-account, e.g. noreply@your-domain>
SMTP_PASSWORD=<mailbox-password>
SMTP_FROM=<noreply@your-domain>
# Where the reset link points (the deployed web app).
FRONTEND_URL=http://localhost:5173
# RESET_TOKEN_TTL_MINUTES=30

# LLM justification layer (ADR-001). Off unless LLM_ENABLED=true AND a key AND a
# system prompt are provided. The system prompt is customer-owned and not
# committed: put it in LLM_SYSTEM_PROMPT or the git-ignored
# backend/llm_system_prompt.txt (see backend/llm_system_prompt.example.txt).
LLM_ENABLED=false
LLM_API=<llm-api-key>
LLM_BASE_URL=https://api.vsellm.ru/v1
LLM_MODEL=openai/gpt-4o-mini
# LLM_SYSTEM_PROMPT=
